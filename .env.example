# =============================================================================
# EventSport — ortam değişkenleri şablonu
# Kullanım: cp .env.example .env  (Windows: copy .env.example .env)
# =============================================================================

# --- MongoDB (Docker Compose: mongodb servisi) ---
MONGO_ROOT_USERNAME=admin
MONGO_ROOT_PASSWORD=admin123
MONGO_DB=sportsevents

# Docker içinde host adı `mongodb` olmalı. Yerel Mongo (auth yok):
# MONGODB_URI=mongodb://localhost:27017/sportsevents
MONGODB_URI=mongodb://admin:admin123@mongodb:27017/sportsevents?authSource=admin
# createDummyEvents.js alternatifi (genelde MONGODB_URI yeterli):
# MONGO_URI=

# --- Backend ---
NODE_ENV=development
PORT=3000
BACKEND_PORT=3000
JWT_SECRET=your_jwt_secret_key_here
JWT_REFRESH_SECRET=your_jwt_refresh_secret_key_here
COOKIE_DOMAIN=localhost
# Tarayıcıda açtığınız frontend URL'leri (CORS)
ALLOWED_ORIGINS=http://localhost:3001,http://127.0.0.1:3001

# Hero banner dahili yönlendirme (Referer yoksa, isteğe bağlı)
PUBLIC_FRONTEND_URL=http://localhost:3001
# FRONTEND_URL=http://localhost:3001

# Etkinlik check-in hatırlatıcı zamanlayıcısı (isteğe bağlı)
CHECK_IN_REMINDERS_ENABLED=true
CHECK_IN_REMINDER_INTERVAL_MS=300000

# Tekrarlayan etkinlik serisi slot başına listeleme ücreti (TRY)
LISTING_PRICE_PER_SLOT=50

# --- Kayıt OTP e-postası (Brevo: smtp-relay.brevo.com, port 587) ---
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=EventSport <noreply@eventsport.local>
SMTP_SECURE=false

# --- Frontend (Next.js — değişiklikten sonra frontEnd'i yeniden build edin) ---
FRONTEND_PORT=3001
NEXT_PUBLIC_API_V1_BASE=http://localhost:3000/api/v1
NEXT_PUBLIC_API_ASSETS_BASE=http://localhost:3000
# Davet paylaşım linkleri (boşsa tarayıcı origin kullanılır)
NEXT_PUBLIC_SITE_URL=http://localhost:3001

# --- Admin (ilk açılışta otomatik oluşturulur) ---
ADMIN_EMAIL=admin@eventsport.com
ADMIN_PASSWORD=Admin123!@#
ADMIN_FIRST_NAME=Admin
ADMIN_LAST_NAME=User
ADMIN_PHONE=09123456789
ADMIN_AGE=1990-01-01
