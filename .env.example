# =============================================================================
# EventSport — ortam değişkenleri şablonu
# Kullanım: cp .env.example .env  (Windows: copy .env.example .env)
# Tüm değerler docker-compose.yml tarafından bu dosyadan okunur.
# docker-compose.yml hiçbir portu host'a expose etmez; servisler arası
# iletişim `eventsport_network` üzerinden container adlarıyla yapılır.
# =============================================================================

# --- Docker (container adları & image etiketleri) ---
MONGO_CONTAINER_NAME=eventSport_mongodb
BACKEND_CONTAINER_NAME=eventSport_backend
FRONTEND_CONTAINER_NAME=eventSport_frontend
NGINX_CONTAINER_NAME=eventSport_nginx
# Tek dışarı açık port (nginx). backend/frontend host'a port açmaz.
HTTP_PORT=3001
# Image etiketleri: image yoksa compose Dockerfile'dan build edip bu tag'i atar.
# Düşük RAM'li sunucularda frontend host'ta önceden build edilip bu tag ile
# image olarak hazır bırakılabilir (bkz: scripts/build-frontend-prebuilt.sh).
BACKEND_IMAGE=eventsport-backend:latest
FRONTEND_IMAGE=eventsport-frontend:latest

# --- MongoDB (Docker Compose: mongodb servisi) ---
MONGO_ROOT_USERNAME=admin
MONGO_ROOT_PASSWORD=admin123
MONGO_DB=sportsevents
# Docker içinde host adı `mongodb` (servis adı) olmalı.
MONGODB_URI=mongodb://admin:admin123@mongodb:27017/sportsevents?authSource=admin

# --- Backend ---
NODE_ENV=development
# Container içi port (host'a expose edilmez). Backend bu portta dinler.
BACKEND_PORT=3000
JWT_SECRET=your_jwt_secret_key_here
JWT_REFRESH_SECRET=your_jwt_refresh_secret_key_here
COOKIE_DOMAIN=localhost
# Tarayıcıda açtığınız adres (nginx tek giriş — CORS)
ALLOWED_ORIGINS=http://localhost:3001,http://127.0.0.1:3001

# Hero banner dahili yönlendirme (Referer yoksa, isteğe bağlı)
PUBLIC_FRONTEND_URL=http://localhost:3001
FRONTEND_URL=http://localhost:3001

# Etkinlik check-in hatırlatıcı zamanlayıcısı (isteğe bağlı)
CHECK_IN_REMINDERS_ENABLED=true
CHECK_IN_REMINDER_INTERVAL_MS=300000

# Tekrarlayan etkinlik serisi slot başına listeleme ücreti (TRY)
LISTING_PRICE_PER_SLOT=50

# --- Kayıt OTP e-postası (Brevo: smtp-relay.brevo.com, port 587) ---
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=EventSport <noreply@eventsport.local>
SMTP_SECURE=false

# --- Frontend (Next.js — değişiklikten sonra frontEnd'i yeniden build edin) ---
# Container içi port (host'a expose edilmez).
FRONTEND_PORT=3001
# Tarayıcıdan ulaşılacak adresler (build-time; nginx /api/ ve /uploads/ proxy eder).
# Sunucuda public URL'inizle değiştirin (örn. https://example.com/api/v1).
NEXT_PUBLIC_API_V1_BASE=http://localhost:3001/api/v1
NEXT_PUBLIC_API_ASSETS_BASE=http://localhost:3001
# Davet paylaşım linkleri (boşsa tarayıcı origin kullanılır)
NEXT_PUBLIC_SITE_URL=http://localhost:3001

# --- Admin (ilk açılışta otomatik oluşturulur) ---
ADMIN_EMAIL=admin@eventsport.com
ADMIN_PASSWORD=Admin123!@#
ADMIN_FIRST_NAME=Admin
ADMIN_LAST_NAME=User
ADMIN_PHONE=09123456789
ADMIN_AGE=1990-01-01
